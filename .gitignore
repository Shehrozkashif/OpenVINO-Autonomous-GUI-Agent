# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ──────────────────────────────────────────────────────
venv/
env/
.venv/

# ── Model files (large — never commit) ──────────────────────────────────────
# OVMS model repository: IR weights, tokenizers, generated config
models/*
!models/.gitkeep

# ── OVMS binary (downloaded by user, not part of source) ────────────────────
ovms/
ovms.zip

# ── OVMS export tool (downloaded by start.py on first run) ──────────────────
tools/ovms/

# ── Generated OVMS launchers (Windows) ──────────────────────────────────────
_run_ovms.bat
_test_ovms.bat

# ── Runtime artifacts ────────────────────────────────────────────────────────
*.log
logs/
@AutomationLog.txt
*.db

# ── Test / lint cache ────────────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
